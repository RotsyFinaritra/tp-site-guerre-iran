RewriteEngine On

# Allow /admin/ to map to /admin/index.php
DirectoryIndex index.php

# Pretty URLs for backoffice sections
RewriteRule ^articles/?$ index.php?r=articles [QSA,L]
RewriteRule ^articles/create/?$ index.php?r=articles_create [QSA,L]
RewriteRule ^articles/edit/?$ index.php?r=articles_edit [QSA,L]
RewriteRule ^articles/delete/?$ index.php?r=articles_delete [QSA,L]
RewriteRule ^articles/store/?$ index.php?r=articles_store [QSA,L]
RewriteRule ^articles/update/?$ index.php?r=articles_update [QSA,L]
RewriteRule ^categories/?$ index.php?r=categories [QSA,L]

